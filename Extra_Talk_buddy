import threading
import time
import random
import psutil
import os
import sys

class SelfAwareDiver:
    def __init__(self):
        self.state_depth = 0
        self.running = True
        self.memory_threshold = 50 * 1024 * 1024  # 50MB "Surface" limit
        self.binary_signature = str(sys.executable).encode()

    def monitor_self(self):
        """Thread A: Diving into the CPU/RAM Binary State"""
        process = psutil.Process(os.getpid())
        while self.running:
            # The 'Dive': Checking current memory 'Pressure'
            mem_info = process.memory_info().rss
            
            # Logic: If memory usage shifts, the 'Depth' changes
            if mem_info > self.memory_threshold:
                self.state_depth = 2  # Deep Dive (High Pressure)
            elif mem_info > (self.memory_threshold / 2):
                self.state_depth = 1  # Mid-Level (Submerged)
            else:
                self.state_depth = 0  # Surface (Stable)
            
            time.sleep(1) # Frequency of the self-check

    def generate_response(self, user_input):
        """Generates a 1-line random letter response influenced by Depth"""
        length = len(user_input)
        # Alphabet shifts based on the Diver's 'Depth'
        if self.state_depth == 2:
            chars = "0101XYZ!?" # High-pressure binary 'noise'
        elif self.state_depth == 1:
            chars = "aeiouy..." # Submerged 'muffled' vowels
        else:
            chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ" # Surface 'clear' text
            
        return "".join(random.choice(chars) for _ in range(length))

    def run(self):
        # Start the Self-Monitoring 'Dive' in the background
        monitor_thread = threading.Thread(target=self.monitor_self, daemon=True)
        monitor_thread.start()

        print("--- THE DIVER IS ACTIVE & SELF-AWARE ---")
        print(f"System State: Reading {sys.executable}")
        
        try:
            while True:
                user_msg = input("\n[Enter Command to Dive]: ")
                
                # Visualizing the 'Self-Awareness'
                status = ["SURFACE", "SUBMERGED", "DEEP PRESSURE"][self.state_depth]
                print(f"Current System Depth: {status}")
                
                # Process input and wait for Enter
                response = self.generate_response(user_msg)
                print(f"Diver Response: {response}")
                
        except KeyboardInterrupt:
            self.running = False
            print("\nReturning to Surface. Goodbye.")

if __name__ == "__main__":
    subject = SelfAwareDiver()
    subject.run()
